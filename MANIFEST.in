include README.md
include LICENSE
include CHANGELOG.md
include pyproject.toml
recursive-include docuvision py.typed
recursive-include docuvision *.py
recursive-include tests *.py
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude .DS_Store
prune build
prune dist
prune *.egg-info
